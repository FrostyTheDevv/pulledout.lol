# Environment Variables for SawSap Security Scanner
# Copy this file to .env and fill in your values

# Flask Secret Key (generate a random secret for production)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database URL
# Development (SQLite): sqlite:///sawsap.db
# Production (Railway PostgreSQL): Will be auto-set by Railway as DATABASE_URL
DATABASE_URL=sqlite:///sawsap.db

# Flask Environment
FLASK_ENV=production

# Server Configuration (Railway sets PORT automatically)
PORT=5000

# Base URL (optional, auto-detects localhost in dev, pulledout.lol in production)
# Only set this if you need a custom URL
# BASE_URL=http://localhost:5000

# Discord OAuth Configuration
# Get these from: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Auto-detected based on BASE_URL, but can override:
# DISCORD_REDIRECT_URI=http://localhost:5000/auth/discord/callback

# Discord Bot Configuration for Guild Verification
# Get bot token from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-server-id
DISCORD_BUYER_ROLE_ID=1484996965195579503
DISCORD_DENIED_ROLE_ID=1484997044618792982

# LemonSqueezy Payment Configuration
# Get these from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_URL=your-store-url
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_PRODUCT_ID=your-product-variant-id

# Railway Environment (auto-set by Railway)
# RAILWAY_ENVIRONMENT=production

# Environment Variables for SawSap Security Scanner
# Copy this file to .env and fill in your values

# Flask Secret Key (generate a random secret for production)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database URL
# Development (SQLite): sqlite:///sawsap.db
# Production (Railway PostgreSQL): Will be auto-set by Railway as DATABASE_URL
DATABASE_URL=sqlite:///sawsap.db

# Flask Environment
FLASK_ENV=production

# Server Configuration (Railway sets PORT automatically)
PORT=5000

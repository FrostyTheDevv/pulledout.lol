{
  "name": "sawsap-frontend",
  "version": "2.0.0",
  "description": "SawSap - Ultra-Secure React Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build && npm run obfuscate",
    "obfuscate": "javascript-obfuscator dist/assets/*.js --output dist/assets --compact true --control-flow-flattening true --dead-code-injection true --debug-protection true --disable-console-output true --string-array true --string-array-encoding 'rc4' --string-array-threshold 0.75",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.0.9",
    "fingerprintjs2": "^2.1.4",
    "framer-motion": "^11.0.3",
    "jose": "^5.2.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.0",
    "socket.io-client": "^4.6.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "javascript-obfuscator": "^4.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vite-plugin-compression": "^0.5.1"
  }
}
